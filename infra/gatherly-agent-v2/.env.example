# =============================================================================
# Gatherly Agent v2 - Environment Variables
# =============================================================================
# Copy this file to .env for local development
# For Railway deployment, set these in the Railway dashboard Variables section
# =============================================================================

# -----------------------------------------------------------------------------
# GATHERLY INTEGRATION (REQUIRED)
# -----------------------------------------------------------------------------

# Internal URL for Gatherly app (Railway private DNS or public URL)
# Railway: http://web.railway.internal:8080
# Local: http://localhost:3000
GATHERLY_BASE_URL=http://web.railway.internal:8080

# Bot API key generated from Gatherly dashboard
# Must exactly match BOT_API_SECRET on the Gatherly app service.
GATHERLY_BOT_API_KEY=gat_your-api-key-here

# Second bot secret for Gatherly assistant hardening
# Must exactly match BOT_API_SECOND_SECRET on the Gatherly app service.
GATHERLY_BOT_SECOND_SECRET=gat_second-secret-here

# Telegram bot token (same token used by both Gatherly and this agent)
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# AUTO-CONFIGURATION (optional — skips /setup wizard)
# -----------------------------------------------------------------------------

# Auth method for the AI provider.
# Defaults to "openai-api-key" (works non-interactively with OPENCLAW_API_KEY).
# OAuth providers (codex-cli, openai-codex) require interactive login via /tui.
OPENCLAW_AUTH_CHOICE=openai-api-key

# API key for the AI provider (only required for API-key-based providers).
# Not needed for codex-cli / openai-codex / other OAuth flows.
OPENCLAW_API_KEY=

# Model to set after onboarding (e.g. "o4-mini", "gpt-4.1").
# Leave empty to use the provider default.
OPENCLAW_MODEL=

# Telegram user ID of the admin — pre-approved in the allowlist.
# The admin can message the bot immediately without going through pairing.
# Find your ID: message @userinfobot on Telegram.
# Must be numeric digits only (example: 123456789).
# If empty/invalid, wrapper falls back to dmPolicy=pairing.
TELEGRAM_ADMIN_ID=

# -----------------------------------------------------------------------------
# REQUIRED VARIABLES
# -----------------------------------------------------------------------------

# Password to access the /setup wizard
# For Railway: Use ${{ secret() }} to generate a random secure password
# For local: Set any password you want
SETUP_PASSWORD=your-secure-password-here

# Directory where openclaw stores configuration and state
# MUST point to /data on Railway (volume mount) for persistence
OPENCLAW_STATE_DIR=/data/.openclaw

# Directory where openclaw stores workspace files
# MUST point to /data on Railway (volume mount) for persistence
OPENCLAW_WORKSPACE_DIR=/data/workspace

# -----------------------------------------------------------------------------
# RECOMMENDED VARIABLES
# -----------------------------------------------------------------------------

# Authentication token for the gateway and Control UI
# For Railway: Use ${{ secret() }} to generate a stable secret
# For local: Generate with: openssl rand -hex 32
# If not set, the wrapper will generate one (not ideal for production)
OPENCLAW_GATEWAY_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL VARIABLES (Usually don't need to change)
# -----------------------------------------------------------------------------

# Port the wrapper server listens on
# Railway sets this automatically, usually to 8080
PORT=8080

# Internal port where the gateway listens (proxied by the wrapper)
# Default: 18789
INTERNAL_GATEWAY_PORT=18789

# Internal host for the gateway
# Default: 127.0.0.1
INTERNAL_GATEWAY_HOST=127.0.0.1

# Path to the configuration file
# Default: ${OPENCLAW_STATE_DIR}/openclaw.json
# Leave empty to use the default
OPENCLAW_CONFIG_PATH=

# Path to the CLI entry point
# Default: /openclaw/dist/entry.js
# Leave empty unless using a custom build
OPENCLAW_ENTRY=/openclaw/dist/entry.js

# Node.js executable to use
# Default: node
OPENCLAW_NODE=node

# Enable debug logging for wrapper token management
# Set to "true" to see detailed token resolution and sync logs
OPENCLAW_TEMPLATE_DEBUG=

# Run `openclaw doctor --fix` automatically on every boot.
# Default is disabled because doctor fixes may reset runtime state.
OPENCLAW_RUN_DOCTOR_ON_BOOT=false

# Telegram channel mode used by this wrapper.
# "polling" (default): wrapper clears stale Telegram webhooks on boot so getUpdates works.
# "webhook": wrapper will not clear webhook.
OPENCLAW_TELEGRAM_CHANNEL_MODE=polling

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. For Railway deployment, you MUST have a Volume mounted at /data
# 2. Without the volume, configuration will be lost on every redeploy
# 3. After deployment, visit https://your-app.up.railway.app/setup to configure
# 4. The setup wizard will guide you through onboarding
# 5. Post-deploy, authenticate AI provider manually:
#    openclaw models auth login --provider openai-codex --set-default
# =============================================================================
