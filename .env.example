# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gatherly"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# Telegram Bot (Assistant plugin)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your_bot_username"

# Bot API Secret (authenticates OpenClaw bot — generate with: pnpm exec tsx ./scripts/generate-bot-secret.ts)
BOT_API_SECRET=""
# Bot API Second Secret (required second factor for assistant bot calls)
BOT_API_SECOND_SECRET=""
# Replay nonce TTL in milliseconds
BOT_REQUEST_NONCE_TTL_MS="300000"

# Node Environment
NODE_ENV="development"
